# ============================================================================
# Compliance Automation Platform — Environment Variables
# ============================================================================
# Copy this file to .env and fill in real values.
# In production, use Azure Key Vault instead (set AZURE_KEYVAULT_URL).
# ============================================================================

# ── Azure Key Vault (if set, all secrets are pulled from KV) ────────────────
# AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net/

# ── LLM / Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com
GEMINI_MODEL_VERSION=gemini-1.5-pro

# ── Azure OpenAI (fallback model) ──────────────────────────────────────────
AOAI_API_KEY=
AOAI_ENDPOINT=
AOAI_DEPLOYMENT=gpt-4o

# ── Azure Cosmos DB ────────────────────────────────────────────────────────
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE=compliancedb

# ── Azure Data Lake Storage Gen2 ───────────────────────────────────────────
ADLS_CONNECTION_STRING=
ADLS_ACCOUNT_NAME=
ADLS_CONTAINER_NAME=compliance-docs

# ── MinIO / Blob Staging ───────────────────────────────────────────────────
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=raw-documents

# ── ServiceNow ─────────────────────────────────────────────────────────────
SERVICENOW_INSTANCE_URL=
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# ── Audit / HMAC ───────────────────────────────────────────────────────────
AUDIT_HMAC_SECRET=
PDF_SIGNING_KEY_PEM=

# ── Alerting (SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
ALERT_SENDER=
ALERT_RECIPIENTS_CSV=

# ── Kill Switch ────────────────────────────────────────────────────────────
KILL_SWITCH_WEBHOOK_URL=

# ── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── AKS / Runtime ─────────────────────────────────────────────────────────
AKS_NAMESPACE=compliance-pilot
MAX_CONCURRENT_CHAINS=10
PIPELINE_TIMEOUT_SECONDS=300

# ── Azure Document Intelligence (Form Recognizer) ─────────────────────────
FORM_RECOGNIZER_ENDPOINT=
FORM_RECOGNIZER_KEY=

# ── Azure AI Search ────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=compliance-chunks

# ── Report Output ──────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports

# ============================================================================
# Project Aegis — Enterprise Feature Environment Variables
# ============================================================================

# ── Phase 1: Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HASH_TTL_DAYS=90
REDIS_SLA_TTL_DAYS=60
REDIS_TENSION_TTL_DAYS=180

# ── Phase 2: SEBI ──────────────────────────────────────────────────────────
SEBI_FEED_URL=https://www.sebi.gov.in/sebiweb/home/HomeAction.do?doListing=yes&sid=4&ssid=&smid=0

# ── Phase 3: Qdrant + Conflict Detection ───────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aegis_chunks
CONFLICT_SIMILARITY_THRESHOLD=0.88
CONFLICT_TOP_K=5

# ── Phase 4: WebSocket ─────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30
